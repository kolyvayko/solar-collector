      "datasource": {
        "type": "prometheus",
        "uid": "victoriametrics"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 20
              },
              {
                "color": "yellow",
                "value": 40
              },
              {
                "color": "green",
                "value": 60
              }
            ]
